# ─── Argus Configuration ──────────────────────────────────
# Copy to ~/.argus/.env and fill in your values

# ─── Claude API ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ARGUS_MODEL=claude-sonnet-4-20250514

# ─── Feedly ───────────────────────────────────────────────
FEEDLY_TOKEN=
FEEDLY_USER_ID=
# Comma-separated stream IDs for categories to monitor
FEEDLY_STREAMS=user/{user_id}/category/ai-security,user/{user_id}/category/security

# ─── Slack ────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#argus-intel

# ─── WhatsApp (via Twilio — optional) ────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ─── Paths ────────────────────────────────────────────────
ARGUS_DATA_DIR=~/.argus/data
ARGUS_LOG_DIR=~/.argus/logs
